{
  "name": "vagudle",
  "version": "1.4.6",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build && node scripts/optimize-dist.mjs",
    "preview": "vite preview",
    "typecheck": "node ./node_modules/typescript-7/bin/tsc --noEmit",
    "lint": "eslint .",
    "format": "svgo -f src -r && svgo -f public -r && prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"functions/**/*.js\" \"*.{html,json,js,cjs,md}\" \"public/**/*.{html,json}\" \".github/**/*.md\" \"scripts/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"functions/**/*.js\" \"*.{html,json,js,cjs,md}\" \"public/**/*.{html,json}\" \".github/**/*.md\" \"scripts/*.mjs\""
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^1.0.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ua-parser-js": "^0.7.39",
    "classnames": "^2.5.1",
    "framer-motion": "^12.42.2",
    "lottie-web": "^5.13.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.1",
    "react-countdown": "^2.3.6",
    "react-dom": "^19.2.1",
    "ua-parser-js": "^1.0.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.19.39",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.7.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.3.2",
    "postcss": "^8.5.19",
    "prettier": "2.5.1",
    "svgo": "^3.0.0",
    "tailwindcss": "^3.0.12",
    "typescript": "^6.0.3",
    "typescript-7": "npm:typescript@^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-svgr": "^5.2.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,css,md}": "prettier --write",
    "src/**/*.svg": "svgo",
    "functions/**/*.js": "prettier --write",
    "*.{html,json,js,cjs,md}": "prettier --write",
    "public/**/*.{html,json}": "prettier --write",
    "public/**/*.svg": "svgo",
    ".github/**/*.md": "prettier --write"
  }
}
